{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./worlify_backend/**)",
      "Read(./worlify_frontend/**)",
      "Read(./docker-compose.yml)",
      "Read(./docker-compose.*.yml)",
      "Read(./CLAUDE.md)",
      "Read(./.claudeignore)",
      "Read(./Dockerfile*)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
