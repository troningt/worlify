# ============================================================
# Worlify - .gitignore raíz del monorepo
# ============================================================
# Este archivo excluye carpetas completas de los submódulos
# para que cada uno gestione su propio .gitignore interno.
# ============================================================

# --- Backend (Spring Boot / Gradle) ---
#/worlify_backend/

# --- Frontend ---
#/worlify_frontend/

# --- OpenJDK ---
.java-version
.jdks/
/openJdk-*/

# --- Docker ---
/docker/*

# --- IDE ---
.idea/

# --- Logs ---
*.log

# --- VSCode ---
.vscode/

# --- Jetbrains ---
.jetBrains/

# --- Local Settings ---
.settings.local.json

# --- Dirty Files ---
.DS_Store
.gradle-cache/
dirty-files

# --- Claude ---
#.claude/