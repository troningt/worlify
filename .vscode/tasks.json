{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker Compose: Start Local Infra (Postgres, Mongo, Redis, Kafka)",
      "type": "shell",
      "command": "docker-compose up -d postgres mongodb redis kafka",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker Compose: Start ALL",
      "type": "shell",
      "command": "docker-compose up -d --build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Docker Compose: Down",
      "type": "shell",
      "command": "docker-compose down",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
